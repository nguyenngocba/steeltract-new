>;
export type CreateAnalyticsAlertDto = z.infer<
  typeof createAnalyticsAlertSchema
>;
export type ListAnalyticsAlertsDto = z.infer<typeof listAnalyticsAlertsSchema>;
export type CreateAnalyticsPredictionDto = z.infer<
