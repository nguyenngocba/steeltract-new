    onSuccess: (_record, variables) =>
      queryClient.invalidateQueries({
        queryKey: queryKeys.masterData.dictionary(
          variables.domain,
        ),
      }),
  })
}

export function useDeactivateMasterDataMutation() {
  const queryClient = useQueryClient()

  return useMutation({
