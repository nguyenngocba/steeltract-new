                setForm({
                  ...form,
                  projectName:
                    e.target.value,
                })
              }
              placeholder="Project Name"
              className="w-full bg-zinc-800 rounded-xl px-4 py-3"
            />

            <input
              value={
                form.requestedBy
              }
              onChange={(e) =>
                setForm({
                  ...form,
                  requestedBy:
                    e.target.value,
                })
              }
              placeholder="Requested By"
              className="w-full bg-zinc-800 rounded-xl px-4 py-3"
            />

            <textarea
