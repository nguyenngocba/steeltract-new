  reason: z.string().optional(),
  metadata: metadataSchema,
});

export const yardSearchSchema = z.object({
  q: z.string().optional(),
  search: z.string().optional(),
  itemType: z.nativeEnum(YardItemType).optional(),
  zoneId: z.string().optional(),
