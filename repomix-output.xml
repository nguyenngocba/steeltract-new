  OperatorAction,
} from './operator-action.types'

interface OperatorActionMenuProps {
  actions: OperatorAction[]
  compact?: boolean
}

export function OperatorActionMenu({
  actions,
  compact = false,
}: OperatorActionMenuProps) {
  return (
    <div
      className={clsx(
        'grid gap-2',
        compact && 'text-xs',
      )}
