  priority          TaskPriority         @default(MEDIUM)
  workCenterId      String?
  machineId         String?
  assignedWorkerId  String?
  plannedStartAt    DateTime?
  plannedEndAt      DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  stage           ProductionStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  workCenter      WorkCenter?      @relation(fields: [workCenterId], references: [id], onDelete: SetNull)
  machine         Machine?         @relation(fields: [machineId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([productionOrderId])
  @@index([stageId])
  @@index([assignedWorkerId])
  @@map("production_tasks")
}

model ProductionSchedule {
  id                String   @id @default(cuid())
  productionOrderId String
  workCenterId      String?
  machineId         String?
  startAt           DateTime
  endAt             DateTime
  capacityPlanned   Float?
  capacityUsed      Float?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  workCenter      WorkCenter?      @relation(fields: [workCenterId], references: [id], onDelete: SetNull)
  machine         Machine?         @relation(fields: [machineId], references: [id], onDelete: SetNull)

  @@index([startAt, endAt])
  @@index([workCenterId])
  @@index([machineId])
  @@map("production_schedules")
}

model ProductionLog {
  id                String            @id @default(cuid())
  productionOrderId String
  stageId           String?
  type              ProductionLogType @default(NOTE)
  message           String
  quantity          Float?
  workerId          String?
  machineId         String?
  attachmentIds     String[]          @default([])
  metadata          Json?
  createdAt         DateTime          @default(now())

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  stage           ProductionStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([productionOrderId])
  @@index([stageId])
  @@index([type])
  @@index([createdAt])
  @@map("production_logs")
}

//
// QUALITY CONTROL
//

model QcChecklist {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  type        QcChecklistType @default(FINAL)
  revision    String          @default("A")
  description String?
  isActive    Boolean         @default(true)
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  items       QcChecklistItem[]
  inspections QcInspection[]

  @@index([type])
  @@index([isActive])
  @@map("qc_checklists")
}

model QcChecklistItem {
  id            String   @id @default(cuid())
  checklistId   String
  sequence      Int
  title         String
  description   String?
  required      Boolean  @default(true)
  expectedValue String?
  tolerance     String?
  unit          String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  checklist QcChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  results   QcResult[]

  @@unique([checklistId, sequence])
  @@index([checklistId])
  @@map("qc_checklist_items")
}

model QcInspection {
  id                 String             @id @default(cuid())
  inspectionNo       String             @unique
  checklistId        String?
  productionOrderId  String?
  productionStageId  String?
  componentId        String?
  projectId          String?
  status             QcInspectionStatus @default(DRAFT)
  inspectorId        String?
  startedAt          DateTime?
  completedAt        DateTime?
  approvedById       String?
  approvedAt         DateTime?
  rejectedById       String?
  rejectedAt         DateTime?
  rejectionReason    String?
  workflowInstanceId String?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  checklist   QcChecklist?            @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  results     QcResult[]
  issues      QcIssue[]
  attachments QcAttachment[]
  ncrs        NonConformanceReport[]

  @@index([status])
  @@index([productionOrderId])
  @@index([productionStageId])
  @@index([componentId])
  @@index([projectId])
  @@index([checklistId])
  @@map("qc_inspections")
}

model QcResult {
  id              String         @id @default(cuid())
  inspectionId    String
  checklistItemId String?
  category        QcChecklistType @default(FINAL)
  status          QcResultStatus @default(PENDING)
  measuredValue   String?
  expectedValue   String?
  tolerance       String?
  unit            String?
  notes           String?
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  inspection    QcInspection     @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  checklistItem QcChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)
  issues        QcIssue[]

  @@index([inspectionId])
  @@index([checklistItemId])
  @@index([category])
  @@index([status])
  @@map("qc_results")
}

model QcIssue {
  id               String          @id @default(cuid())
  inspectionId     String
  resultId         String?
  code             String?
  title            String
  description      String?
  severity         QcIssueSeverity @default(MEDIUM)
  status           QcIssueStatus   @default(OPEN)
  correctiveAction String?
  assignedToId     String?
  createdById      String?
  dueAt            DateTime?
  resolvedAt       DateTime?
  verifiedAt       DateTime?
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  inspection  QcInspection           @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  result      QcResult?              @relation(fields: [resultId], references: [id], onDelete: SetNull)
  attachments QcAttachment[]
  ncrs        NonConformanceReport[]

  @@index([inspectionId])
  @@index([resultId])
  @@index([severity])
  @@index([status])
  @@map("qc_issues")
}

model QcAttachment {
  id           String   @id @default(cuid())
  inspectionId String?
  issueId      String?
  ncrId        String?
  attachmentId String
  purpose      String   @default("")
  metadata     Json?
  createdAt    DateTime @default(now())

  inspection QcInspection?         @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  issue      QcIssue?              @relation(fields: [issueId], references: [id], onDelete: Cascade)
  ncr        NonConformanceReport? @relation(fields: [ncrId], references: [id], onDelete: Cascade)
  attachment Attachment            @relation(fields: [attachmentId], references: [id], onDelete: Restrict)

  @@index([inspectionId])
  @@index([issueId])
  @@index([ncrId])
  @@index([attachmentId])
  @@map("qc_attachments")
}

model NonConformanceReport {
  id                String          @id @default(cuid())
  ncrNo             String          @unique
  inspectionId      String
  issueId           String?
  productionOrderId String?
  componentId       String?
  status            NcrStatus       @default(OPEN)
  severity          QcIssueSeverity @default(HIGH)
  title             String
  description       String?
  rootCause         String?
  correctiveAction  String?
  disposition       String?
  raisedById        String?
  approvedById      String?
  closedAt          DateTime?
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  inspection  QcInspection   @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  issue       QcIssue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
  attachments QcAttachment[]

  @@index([inspectionId])
  @@index([issueId])
  @@index([productionOrderId])
  @@index([componentId])
  @@index([status])
  @@index([severity])
  @@map("non_conformance_reports")
}

//
// YARD
//

model YardZone {
  id          String         @id @default(cuid())
  code        String         @unique
  name        String
  description String?
  status      YardZoneStatus @default(ACTIVE)
  originX     Float          @default(0)
  originY     Float          @default(0)
  width       Float          @default(0)
  height      Float          @default(0)
  color       String         @default("#06b6d4")
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  rows      YardRow[]
  slots     YardSlot[]
  snapshots YardSnapshot[]

  @@index([status])
  @@map("yard_zones")
}

model YardRow {
  id        String   @id @default(cuid())
  zoneId    String
  code      String
  name      String?
  index     Int
  originX   Float    @default(0)
  originY   Float    @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zone  YardZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  slots YardSlot[]

  @@unique([zoneId, code])
  @@unique([zoneId, index])
  @@index([zoneId])
  @@map("yard_rows")
}

model YardSlot {
  id             String         @id @default(cuid())
  zoneId         String
  rowId          String?
  code           String
  status         YardSlotStatus @default(AVAILABLE)
  x              Float
  y              Float
  width          Float          @default(1)
  height         Float          @default(1)
  maxStackLevel  Int            @default(1)
  currentStackLevel Int         @default(0)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  zone       YardZone             @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  row        YardRow?             @relation(fields: [rowId], references: [id], onDelete: SetNull)
  placements YardItemPlacement[]
  fromMoves  YardMovement[]       @relation("YardMovementFromSlot")
  toMoves    YardMovement[]       @relation("YardMovementToSlot")

  @@unique([zoneId, code])
  @@index([zoneId])
  @@index([rowId])
  @@index([status])
  @@map("yard_slots")
}

model YardItemPlacement {
  id             String       @id @default(cuid())
  slotId         String
  itemType       YardItemType
  itemId         String
  itemCode       String
  itemName       String?
  quantity       Float        @default(1)
  stackLevel     Int          @default(1)
  weight         Float?
  length         Float?
  width          Float?
  height         Float?
  placedById     String?
  placedAt       DateTime     @default(now())
  removedAt      DateTime?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  slot      YardSlot       @relation(fields: [slotId], references: [id], onDelete: Restrict)
  movements YardMovement[]

  @@index([slotId])
  @@index([itemType, itemId])
  @@index([itemCode])
  @@index([removedAt])
  @@map("yard_item_placements")
}

model YardMovement {
  id            String           @id @default(cuid())
  placementId   String?
  type          YardMovementType
  itemType      YardItemType
  itemId        String
  itemCode      String
  fromSlotId    String?
  toSlotId      String?
  craneId       String?
  movedById     String?
  reason        String?
  metadata      Json?
  createdAt     DateTime         @default(now())

  placement YardItemPlacement? @relation(fields: [placementId], references: [id], onDelete: SetNull)
  fromSlot  YardSlot?          @relation("YardMovementFromSlot", fields: [fromSlotId], references: [id], onDelete: SetNull)
  toSlot    YardSlot?          @relation("YardMovementToSlot", fields: [toSlotId], references: [id], onDelete: SetNull)
  crane     Crane?             @relation(fields: [craneId], references: [id], onDelete: SetNull)

  @@index([itemType, itemId])
  @@index([fromSlotId])
  @@index([toSlotId])
  @@index([craneId])
  @@index([createdAt])
  @@map("yard_movements")
}

model Crane {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  status      CraneStatus @default(AVAILABLE)
  currentX    Float       @default(0)
  currentY    Float       @default(0)
  utilization Float       @default(0)
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  movements YardMovement[]

  @@index([status])
  @@map("cranes")
}

model YardSnapshot {
  id           String   @id @default(cuid())
  zoneId       String?
  name         String
  occupancyRate Float   @default(0)
  totalSlots   Int      @default(0)
  occupiedSlots Int     @default(0)
  heatmap      Json?
  congestion   Json?
  payload      Json
  generatedById String?
  createdAt    DateTime @default(now())

  zone YardZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([zoneId])
  @@index([createdAt])
  @@map("yard_snapshots")
}

//
// ACTIVITY LOGS
//

model ActivityLog {
  id String @id @default(cuid())

  action String

  entity String

  entityId String?

  module String?

  userId String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])

  @@map("activity_logs")
}

# =========================================================
# SUPPLIER
# =========================================================

model Supplier {

  id          String   @id @default(uuid())

  code        String   @unique

  name        String

  contact     String?

  phone       String?

  email       String?

  address     String?

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt
}

# =========================================================
# PURCHASE RECEIVING
# =========================================================

model PurchaseReceiving {

  id            String   @id @default(uuid())

  receivingNo   String   @unique

  supplierId    String

  materialId    String

  quantity      Float

  status        String   @default("RECEIVED")

  createdAt     DateTime @default(now())
}

# =========================================================
# BOM
# =========================================================

model BOM {

  id            String   @id @default(uuid())

  bomNo         String   @unique

  productCode   String

  productName   String

  version       String

  status        String   @default("ACTIVE")

  createdAt     DateTime @default(now())

  items         BOMItem[]
}

model BOMItem {

  id            String   @id @default(uuid())

  bomId         String

  materialId    String

  quantity      Float

  bom           BOM @relation(fields: [bomId], references: [id])
}

# =========================================================
# WORK ORDER
# =========================================================

model WorkOrder {

  id              String   @id @default(uuid())

  workOrderNo     String   @unique

  productCode     String

  quantity         Float

  plannedStart    DateTime?

  plannedEnd      DateTime?

  status          String   @default("PLANNED")

  createdAt       DateTime @default(now())
}

# =========================================================
# PRODUCTION SCHEDULE
# =========================================================

model ProductionSchedule {

  id              String   @id @default(uuid())

  scheduleNo      String   @unique

  machine         String

  shift           String

  workOrderId     String

  scheduledDate   DateTime

  status          String   @default("SCHEDULED")
}
