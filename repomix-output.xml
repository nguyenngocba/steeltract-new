Rate),\n          description:\n            'Inspection quality signal',\n        },\n        {\n          id: 'yard',\n          label: 'Yard occupancy',\n          value: formatMetricValue(\n            yard?.occupancyRate ??\n              yardOccupancy?.value,\n            '%',\n          ),\n          severity:\n            (yard?.occupancyRate ?? 0) > 85\n              ? 'critical'\n              : metricSeverity(yardOccupancy),\n          description:\n            'Storage congestion',\n        },\n        {\n          id: 'machine',\n          label: 'Machine utilization',\n          value: formatMetricValue(\n            machineUtilizationValue,\n            '%',\n          ),\n          severity: metricSeverity(\n            machineUtilization,\n          ),\n          description:\n            'Factory load signal',\n        },\n      ]","file_path":"src/modules/command-center/CommandCenterLayout.tsx","start_line":242,"end_line":296,"language":"tsx","location":"src/modules/command-center/CommandCenterLayout.tsx:242-296"},{"content":"if (mode === 'production') {\n        return base.filter((item) =>\n          [\n            'production',\n            'machine',\n            'yard',\n          ].includes(item.id),\n        )\n      }\n\n      if (mode === 'qc') {\n        return base.filter((item) =>\n          ['qc', 'production'].includes(\n            item.id,\n          ),\n        )\n      }\n\n      if (mode === 'logistics') {\n        return base.filter((item) =>\n          ['yard', 'production'].includes(\n            item.id,\n          ),\n        )\n      }\n\n      return base\n    },\n    [\n      mode,\n      machineUtilizationValue,\n      production?.totalOrders,\n      qc?.passRate,\n      snapshotMetrics,\n      yard?.occupancyRate,\n    ],\n  )\n\n  const isLoading =\n    analyticsQuery.isLoading &&\n    !snapshot\n\n  if (isLoading) {\n    return (\n      <PageLayout\n        title=\"Command Center\"\n        description=\"Loading realt