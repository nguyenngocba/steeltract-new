}

export async function getComponents(
  params?: ListParams,
) {
  const response =
    await api.get<ComponentItem[]>(
      '/components',
      {
        params,
      },
    )

  return response.data
}

export async function createComponent(
  payload: CreateComponentPayload,
) {
  const response =
    await api.post<ComponentItem>(
