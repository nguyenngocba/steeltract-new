import {
  useMutation,
  useQuery,
  useQueryClient,
} from '@tanstack/react-query'

import { invalidateJobs } from '../query/invalidation'
import { queryKeys } from '../query/query-keys'
import {
  getJob,
  getJobs,
  retryJob,
  runWorkerTick,
  scheduleJob,
} from './jobs-api'

