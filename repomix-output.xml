st',\n      ),\n    ])\n\n    setAnalytics(\n      analyticsResponse.data,\n    )\n\n    setForecast(\n      forecastResponse.data,\n    )\n  }\n\n  async function exportPdf() {\n    const element =\n      document.getElementById(\n        'executive-report',\n      )\n\n    if (!element) {\n      return\n    }\n\n    const canvas =\n      await html2canvas(\n        element,\n      )\n\n    const imgData =\n      canvas.toDataURL(\n        'image/png',\n      )\n\n    const pdf =\n      new jsPDF({\n        orientation:\n          'portrait',\n        unit: 'px',\n        format: 'a4',\n      })\n\n    pdf.addImage(\n      imgData,\n      'PNG',\n      20,\n      20,\n      550,\n      700,\n    )\n\n    pdf.save(\n      'executive-report.pdf',\n    )\n  }","file_path":"src/pages/executive/ExecutiveDashboardPage.tsx","start_line":1,"end_line":88,"language":"tsx","location":"src/pages/executive/ExecutiveDashboardPage.tsx:1-88"},{"content":"function exportExcel() {\n    const worksheet =\n      XLSX.utils.json_to_sheet([\n        analytics,\n        forecast,\n      ])\n\n    const workbook =\n      XLSX.utils.book_new()\n\n    XLSX.utils.book_append_sheet(\n      workbook,\n      worksheet,\n      'Executive',\n    )\n\n    const excelBuffer =\n      XLSX.write(\n        workbook,\n        {\n          bookType: 'xlsx',\n          type: 'array',\n        },\n      )\n\n    const fileData =\n      new Blob(\n        [excelBuffer],\n        {\n          type:\n            'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;charset=UTF-8',\n        },\n      )\n\n    saveAs(\n      fileData,\n      'executive-report.xlsx',\n    )\n  }\n\n  useEffect(() => {\n    loadData()\n  }, [])\n\n  if (\n    !analytics ||\n    !forecast\n  ) {\n    return (\n      <div className=\"text-white\">\n        Loading...\n      </div>\n    )\n  }\n\n  return (","file_path":"src/pages/executive/ExecutiveDashboardPage.tsx","start_line":90,"end_line":145,"language":"tsx","lo