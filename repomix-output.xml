import type {
  ReactNode,
} from 'react'

export type OperatorActionDomain =
  | 'production'
  | 'qc'
  | 'yard'
  | 'inventory'
  | 'workflow'
  | 'procurement'
  | 'supplier'

export interface OperatorActionContext {
