generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum TransactionType {
  IMPORT
  EXPORT
  TRANSFER
  RETURN
  ADJUSTMENT
}

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  email     String?    @unique
  password  String
  fullName  String?
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

model InventoryCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id String @id @default(cuid())

  code String @unique

  name String

  description String?

  quantity Float @default(0)

  minimumStock Float @default(0)

  unit String?

  categoryId String

  zoneId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  category InventoryCategory @relation(fields: [categoryId], references: [id])

  zone WarehouseZone? @relation(fields: [zoneId], references: [id])

  transactionItems InventoryTransactionItem[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id        String          @id @default(cuid())
  code      String          @unique
  type      TransactionType
  note      String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  items InventoryTransactionItem[]

  @@map("inventory_transactions")
}

model InventoryTransactionItem {
  id              String   @id @default(cuid())
  transactionId   String
  inventoryItemId String
  quantity        Float
  createdAt       DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  transaction InventoryTransaction @relation(fields: [transactionId], references: [id])

  @@map("inventory_transaction_items")
}

model Project {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  components  Component[]

  @@map("projects")
}

model Component {
  id String @id @default(cuid())

  code String @unique

  name String

  description String?

  projectId String?

  floor String?

  zone String?

  position String?

  x Float? @default(0)

  y Float? @default(0)

  status String? @default("STOCK")

  plannedDate DateTime?

  installedDate DateTime?

  imageUrl String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id])

  timelines ComponentTimeline[]

  tasks Task[]

  estimatedCost Float @default(0)

  actualCost Float @default(0)

  @@map("components")
}

model ComponentTimeline {
  id String @id @default(cuid())

  componentId String

  action String

  note String?

  createdAt DateTime @default(now())

  component Component @relation(fields: [componentId], references: [id])

  photoUrl String?

  @@map("component_timelines")
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?

  status   TaskStatus   @default(PENDING)
  priority TaskPriority @default(MEDIUM)

  dueDate DateTime?

  componentId String?
  component   Component? @relation(fields: [componentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Attendance {
  id String @id @default(cuid())

  workerName String

  checkIn DateTime @default(now())

  checkOut DateTime?

  createdAt DateTime @default(now())

  @@map("attendance")
}

model SupplierScore {
  id String @id @default(cuid())

  supplierName String

  quality Float @default(0)

  delivery Float @default(0)

  pricing Float @default(0)

  overall Float @default(0)

  createdAt DateTime @default(now())

  @@map("supplier_scores")
}

model EquipmentBooking {
  id String @id @default(cuid())

  equipmentName String

  projectName String

  assignedTo String

  startDate DateTime

  endDate DateTime

  createdAt DateTime @default(now())

  @@map("equipment_bookings")
}

model WarehouseZone {
  id String @id @default(cuid())

  code String @unique

  name String

  description String?

  color String @default("#06b6d4")

  createdAt      DateTime        @default(now())
  inventoryItems InventoryItem[]

  @@map("warehouse_zones")
}

model SiteLog {
  id          String @id @default(cuid())

  title       String

  description String

  weather     String?

  createdBy   String

  createdAt   DateTime @default(now())

  @@map("site_logs")
}

model SafetyInspection {
  id          String @id @default(cuid())

  title       String

  location    String

  inspector   String

  status      String @default("OPEN")

  note        String?

  score       Float @default(0)

  createdAt   DateTime @default(now())

  @@map("safety_inspections")
}

model Vehicle {
  id            String @id @default(cuid())

  plateNumber   String @unique

  name          String

  type          String

  driverName    String?

  fuelType      String?

  status        String @default("ACTIVE")

  createdAt     DateTime @default(now())

  @@map("vehicles")
}

model MaterialRequest {
  id            String @id @default(cuid())

  requestNumber String @unique

  projectName   String

  requestedBy   String

  status        String @default("PENDING")

  note          String?

  createdAt     DateTime @default(now())

  items         MaterialRequestItem[]

  @@map("material_requests")
}

model MaterialRequestItem {
  id          String @id @default(cuid())

  requestId   String

  itemName    String

  quantity    Float

  unit        String?

  createdAt   DateTime @default(now())

  request MaterialRequest @relation(fields: [requestId],references: [id])

  @@map("material_request_items")
}

model Approval {
  id            String @id @default(cuid())

  module        String

  referenceId   String

  requester     String

  approver      String?

  status        String @default("PENDING")

  note          String?

  createdAt     DateTime @default(now())

  approvedAt    DateTime?

  @@map("approvals")
}

model PurchaseOrder {
  id            String @id @default(cuid())

  poNumber      String @unique

  supplierName  String

  projectName   String?

  requestedBy   String

  status        String @default("DRAFT")

  totalAmount   Float @default(0)

  note          String?

  createdAt     DateTime @default(now())

  items         PurchaseOrderItem[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id            String @id @default(cuid())

  purchaseOrderId String

  itemName      String

  quantity      Float

  unitPrice     Float

  totalPrice    Float

  createdAt     DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId],references: [id])

  @@map("purchase_order_items")
}

model AnalyticsSnapshot {
  id                String @id @default(cuid())

  totalProjects     Int @default(0)

  totalComponents   Int @default(0)

  completedProjects Int @default(0)

  delayedProjects   Int @default(0)

  inventoryValue    Float @default(0)

  purchaseTotal     Float @default(0)

  createdAt         DateTime @default(now())

  @@map("analytics_snapshots")
}

model Worker {
  id            String @id @default(cuid())

  employeeCode  String @unique

  fullName      String

  position      String

  team          String?

  phone         String?

  status        String @default("ACTIVE")

  skill         String?

  createdAt     DateTime @default(now())

  @@map("workers")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}
