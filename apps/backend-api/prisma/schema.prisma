generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum TransactionType {
  IMPORT
  EXPORT
  TRANSFER
  RETURN
  ADJUSTMENT
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  DELAYED
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ComponentStatus {
  STOCK
  CUTTING
  WELDING
  PAINTING
  READY
  SHIPPED
  DELIVERED
  INSTALLED
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum InspectionStatus {
  OPEN
  CLOSED
  FAILED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

//
// USER
//

model User {
  id        String     @id @default(cuid())
  username  String     @unique
  email     String?    @unique
  password  String
  fullName  String?
  status    UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

//
// INVENTORY
//

model InventoryCategory {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items InventoryItem[]

  @@map("inventory_categories")
}

model InventoryItem {
  id String @id @default(cuid())

  code String @unique

  name String

  description String?

  quantity Float @default(0)

  minimumStock Float @default(0)

  unit String?

  categoryId String

  zoneId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  category InventoryCategory @relation(fields: [categoryId], references: [id])

  zone WarehouseZone? @relation(fields: [zoneId], references: [id])

  transactionItems InventoryTransactionItem[]

  @@index([code])
  @@index([name])

  @@map("inventory_items")
}

model InventoryTransaction {
  id String @id @default(cuid())

  code String @unique

  type TransactionType

  note String?

  performedBy String?

  referenceModule String?

  referenceId String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  items InventoryTransactionItem[]

  @@index([type])

  @@map("inventory_transactions")
}

model InventoryTransactionItem {
  id String @id @default(cuid())

  transactionId String

  inventoryItemId String

  quantity Float

  createdAt DateTime @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  transaction InventoryTransaction @relation(fields: [transactionId], references: [id])

  @@map("inventory_transaction_items")
}

//
// PROJECTS
//

model Project {
  id String @id @default(cuid())

  code String @unique

  name String

  description String?

  status ProjectStatus @default(PLANNING)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  components Component[]

  @@index([status])

  @@map("projects")
}

model Component {
  id String @id @default(cuid())

  code String @unique

  name String

  description String?

  projectId String?

  floor String?

  zone String?

  position String?

  x Float? @default(0)

  y Float? @default(0)

  status ComponentStatus @default(STOCK)

  plannedDate DateTime?

  installedDate DateTime?

  imageUrl String?

  estimatedCost Float @default(0)

  actualCost Float @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  project Project? @relation(fields: [projectId], references: [id])

  timelines ComponentTimeline[]

  tasks Task[]

  @@index([status])
  @@index([projectId])

  @@map("components")
}

model ComponentTimeline {
  id String @id @default(cuid())

  componentId String

  action String

  note String?

  photoUrl String?

  createdAt DateTime @default(now())

  component Component @relation(fields: [componentId], references: [id])

  @@map("component_timelines")
}

//
// TASKS
//

model Task {
  id String @id @default(cuid())

  title String

  description String?

  status TaskStatus @default(PENDING)

  priority TaskPriority @default(MEDIUM)

  dueDate DateTime?

  componentId String?

  component Component? @relation(fields: [componentId], references: [id])

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([status])

  @@map("tasks")
}

//
// WORKERS
//

model Worker {
  id String @id @default(cuid())

  employeeCode String @unique

  fullName String

  position String

  team String?

  phone String?

  skill String?

  status WorkerStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([status])

  @@map("workers")
}

model Attendance {
  id String @id @default(cuid())

  workerName String

  checkIn DateTime @default(now())

  checkOut DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("attendance")
}

//
// VEHICLES
//

model Vehicle {
  id String @id @default(cuid())

  plateNumber String @unique

  name String

  type String

  driverName String?

  fuelType String?

  status VehicleStatus @default(ACTIVE)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([status])

  @@map("vehicles")
}

//
// SAFETY
//

model SafetyInspection {
  id String @id @default(cuid())

  title String

  location String

  inspector String

  status InspectionStatus @default(OPEN)

  note String?

  score Float @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([status])

  @@map("safety_inspections")
}

//
// PURCHASE
//

model PurchaseOrder {
  id String @id @default(cuid())

  poNumber String @unique

  supplierName String

  projectName String?

  requestedBy String

  status PurchaseOrderStatus @default(DRAFT)

  totalAmount Float @default(0)

  note String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  items PurchaseOrderItem[]

  @@index([status])

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id String @id @default(cuid())

  purchaseOrderId String

  itemName String

  quantity Float

  unitPrice Float

  totalPrice Float

  createdAt DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  @@map("purchase_order_items")
}

//
// MATERIAL REQUEST
//

model MaterialRequest {
  id String @id @default(cuid())

  requestNumber String @unique

  projectName String

  requestedBy String

  status ApprovalStatus @default(PENDING)

  note String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  items MaterialRequestItem[]

  @@index([status])

  @@map("material_requests")
}

model MaterialRequestItem {
  id String @id @default(cuid())

  requestId String

  itemName String

  quantity Float

  unit String?

  createdAt DateTime @default(now())

  request MaterialRequest @relation(fields: [requestId], references: [id])

  @@map("material_request_items")
}

//
// APPROVAL
//

model Approval {
  id String @id @default(cuid())

  module String

  referenceId String

  requester String

  approver String?

  status ApprovalStatus @default(PENDING)

  note String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  approvedAt DateTime?

  @@index([status])

  @@map("approvals")
}

//
// WAREHOUSE
//

model WarehouseZone {
  id String @id @default(cuid())

  code String @unique

  name String

  description String?

  color String @default("#06b6d4")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  inventoryItems InventoryItem[]

  @@map("warehouse_zones")
}

//
// SITE LOGS
//

model SiteLog {
  id String @id @default(cuid())

  title String

  description String

  weather String?

  createdBy String

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("site_logs")
}

//
// SUPPLIER
//

model SupplierScore {
  id String @id @default(cuid())

  supplierName String

  quality Float @default(0)

  delivery Float @default(0)

  pricing Float @default(0)

  overall Float @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("supplier_scores")
}

//
// EQUIPMENT
//

model EquipmentBooking {
  id String @id @default(cuid())

  equipmentName String

  projectName String

  assignedTo String

  startDate DateTime

  endDate DateTime

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("equipment_bookings")
}

//
// ANALYTICS
//

model AnalyticsSnapshot {
  id String @id @default(cuid())

  totalProjects Int @default(0)

  totalComponents Int @default(0)

  completedProjects Int @default(0)

  delayedProjects Int @default(0)

  inventoryValue Float @default(0)

  purchaseTotal Float @default(0)

  createdAt DateTime @default(now())

  @@map("analytics_snapshots")
}

//
// NOTIFICATIONS
//

model Notification {
  id String @id @default(cuid())

  title String

  message String

  type String?

  severity String?

  link String?

  userId String?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@map("notifications")
}

//
// ACTIVITY LOGS
//

model ActivityLog {
  id String @id @default(cuid())

  action String

  entity String

  entityId String?

  module String?

  userId String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([createdAt])

  @@map("activity_logs")
}